generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/paul_international_school/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Staff {
  id            Int     @id @default(autoincrement())
  sno           Int
  name          String
  designation   String
  qualification String
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  description String
  category    String
}

model GalleryImage {
  id      Int    @id @default(autoincrement())
  url     String
  caption String
  album   String
  ord     Int    @default(0)
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
